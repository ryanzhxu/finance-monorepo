            },
            "title": "Results",
            "type": "array"
          },
          "screen_type": {
            "$ref": "#/components/schemas/ScreenType",
            "default": "trending"
          },
          "universe": {
            "$ref": "#/components/schemas/Universe"
          }
        },
        "required": [
          "generated_at",
          "universe",
          "market_regime",
          "data_quality_score",
          "confidence",
          "data_freshness",
          "results"
        ],
        "title": "TrendingScreenResponse",
        "type": "object"
      },
      "Universe": {
        "enum": [
          "SP500",
          "NASDAQ100",
          "DOW",
          "RUSSELL1000",
          "RUSSELL2000",
          "WATCHLIST",
          "CUSTOM"
        ],
        "title": "Universe",
        "type": "string"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
